generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  bio          String?
  profileImage String?
  role         String   @default("AUTHOR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
}

model Post {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  content           String
  isPublished       Boolean   @default(false)
  publishedAt       DateTime?
  locale            String    @default("tr")
  translationOfId   String?
  categoryId        String?
  authorId          String?
  featuredMediaId   String?
  metaTitle         String?
  metaDescription   String?
  canonicalUrl      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  embedCode         String?
  legalDocType      String?
  legalJurisdiction String?
  legalPdfTitle     String?
  legalPdfUrl       String?
  legalRefNumber    String?
  postType          String    @default("LEGAL")
  showCommentary    Boolean   @default(true)
  showSourceBlock   Boolean   @default(true)
  sourceAuthor      String?
  sourceDate        String?
  sourceExcerpt     String?
  sourceImageUrl    String?
  sourcePlatform    String?
  sourceTitle       String?
  sourceUrl         String?
  faqs              FAQ[]
  author            User?     @relation(fields: [authorId], references: [id])
  category          Category? @relation(fields: [categoryId], references: [id])
  featuredMedia     Media?    @relation(fields: [featuredMediaId], references: [id])
  translationOf     Post?     @relation("PostTranslations", fields: [translationOfId], references: [id])
  translations      Post[]    @relation("PostTranslations")
  tags              Tag[]     @relation("PostTags")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]   @relation("PostTags")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  fileName  String
  fileType  String
  altText   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model SiteContent {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model PageSection {
  id        String   @id @default(cuid())
  pageId    String
  type      String
  order     Int
  isVisible Boolean  @default(true)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId, order])
}

model FooterLink {
  id           String   @id @default(cuid())
  label        String
  url          String
  column       String
  order        Int      @default(0)
  openInNewTab Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  locale       String   @default("tr")

  @@index([column, locale, order])
}

model HeaderLink {
  id           String   @id @default(cuid())
  label        String
  url          String
  locale       String   @default("tr")
  order        Int      @default(0)
  openInNewTab Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([locale, order])
}

model CustomPage {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String
  locale          String   @default("tr")
  isPublished     Boolean  @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
